#!/usr/bin/env bash
# Lawful Nova CLI wrapper — Linux and macOS.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../setup/lib/common.sh
source "${SCRIPT_DIR}/../setup/lib/common.sh"

REPO_ROOT="$(lawful_nova_repo_root)"
PY="$(lawful_nova_python)"
lawful_nova_export_paths
cd "${REPO_ROOT}"

exec "${PY}" -m nova.cli "$@"
