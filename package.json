{
  "name": "sovereign-agent",
  "version": "0.9.1-mission-004",
  "description": "Constitutional agentic coding system with governed execution",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "test": "tsc --noEmit && node --require tsx --test tests/**/*.test.ts",
    "test:integration": "tsc --noEmit && node --require tsx --test tests/integration/**/*.test.ts",
    "db:migrate": "tsx src/persistence/migrate.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.26.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.28.0",
    "pino": "^9.14.0",
    "pino-pretty": "^10.3.1",
    "prisma": "^7.8.0",
    "sql.js": "^1.10.3",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/fastify-rate-limit": "^2.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.24",
    "@types/sql.js": "^1.4.4",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
