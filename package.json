{
  "name": "sovereign-agent",
  "version": "0.9.1-mission-004",
  "description": "Constitutional agentic coding system with governed execution",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch backend/server.ts",
    "dev:spine": "tsx watch backend/server.ts",
    "dev:api": "tsx watch backend/server.ts",
    "dev:cockpit": "npm run dev --prefix cockpit",
    "dev:demo": "tsx watch src/index.ts",
    "start": "tsx backend/server.ts",
    "start:api": "tsx backend/server.ts",
    "start:demo": "node dist/src/index.js",
    "nova": "tsx agent/cli.ts",
    "test": "node --require tsx --test tests/**/*.test.ts",
    "test:typecheck": "tsc --noEmit",
    "test:crvs": "node --require tsx --test tests/crvs.test.ts",
    "test:cockpit": "npm run test:crvs && npm run typecheck --prefix cockpit",
    "typecheck:cockpit": "npm run typecheck --prefix cockpit",
    "test:integration": "node --require tsx --test tests/integration/**/*.test.ts",
    "db:migrate": "tsx src/persistence/migrate.ts",
    "lint": "eslint src --ext .ts",
    "mythar:compile": "echo Compile Mythar",
    "ulx:build": "npm run build --prefix ulx"
  },
  "bin": {
    "nova": "./scripts/nova.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "@prisma/client": "^7.9.0",
    "bcryptjs": "^2.4.3",
    "commander": "^12.1.0",
    "fastify": "^5.6.2",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.28.0",
    "pino": "^10.1.1",
    "pino-pretty": "^10.3.1",
    "prisma": "^7.9.0",
    "sql.js": "^1.10.3",
    "uuid": "^9.0.1",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/fastify-rate-limit": "^2.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.24",
    "@types/sql.js": "^1.4.4",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "mysql2@3.15.3": "3.23.1"
  }
}