// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

enum Permission {
  // User permissions
  USER_READ
  USER_WRITE
  USER_DELETE
  
  // Organization permissions
  ORG_READ
  ORG_WRITE
  ORG_DELETE
  
  // Project permissions
  PROJECT_READ
  PROJECT_WRITE
  PROJECT_DELETE
  
  // Ledger permissions
  LEDGER_READ
  LEDGER_WRITE
  LEDGER_DELETE
  
  // Backup permissions
  BACKUP_READ
  BACKUP_WRITE
  BACKUP_RESTORE
  
  // System permissions
  SYSTEM_READ
  SYSTEM_WRITE
  SYSTEM_ADMIN
}

enum ProviderName {
  OPENAI
  ANTHROPIC
  OLLAMA
  LOCAL
}

enum IntentType {
  CODE_GENERATION
  REFACTOR
  ANALYSIS
  TEST_GENERATION
  DOCUMENTATION
  DEBUG
  REVIEW
}

enum TrustTier {
  SOVEREIGN
  VERIFIED
  PROVISIONAL
  QUARANTINED
  EXPELLED
}

enum FeatureFlagStatus {
  ENABLED
  DISABLED
  GRADUAL_ROLLOUT
}

model Organization {
  id              String    @id @default(uuid())
  name            String
  slug            String    @unique
  description     String?
  settings        Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users           User[]
  projects        Project[]
  featureFlags    FeatureFlag[]
  webhooks        Webhook[]
  inviteTokens    InviteToken[]

  @@index([slug])
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  apiKey          String    @unique
  role            UserRole  @default(VIEWER)
  firstName       String?
  lastName        String?
  avatarUrl       String?
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  auditLogs       AuditLog[]
  inviteTokens    InviteToken[] @relation("InvitedTokens")
  permissions     UserPermission[]

  @@index([organizationId])
  @@index([email])
  @@index([apiKey])
}

model Project {
  id              String    @id @default(uuid())
  name            String
  slug            String
  description     String?
  settings        Json      @default("{}")
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId])
}


model LedgerEntry {
  id              String    @id @default(uuid())
  intent          String
  intentType      IntentType
  actor           String
  evidence        Json      // ConstitutionalEvidenceEnvelope
  result          Json?     // Completion output
  trustScore      Float?
  trustTier       TrustTier?
  requestId       String    @unique
  createdAt       DateTime  @default(now())

  organizationId  String
  projectId       String?

  receipt         Receipt?

  @@index([organizationId])
  @@index([projectId])
  @@index([actor])
  @@index([createdAt])
  @@index([requestId])
}

model Receipt {
  id              String    @id @default(uuid())
  ledgerEntryId   String    @unique
  provider        ProviderName
  model           String
  tokensIn        Int
  tokensOut       Int
  costUsd         Float
  latencyMs       Int
  rawResponse     Json?
  createdAt       DateTime  @default(now())

  ledgerEntry     LedgerEntry @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)

  @@index([provider])
  @@index([createdAt])
}

model Snapshot {
  id              String    @id @default(uuid())
  name            String?
  state           Json
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now())

  organizationId  String
  projectId       String?

  @@index([organizationId])
  @@index([projectId])
  @@index([createdAt])
}

model FeatureFlag {
  id              String    @id @default(uuid())
  key             String
  name            String
  description     String?
  status          FeatureFlagStatus @default(DISABLED)
  rolloutPercent  Int       @default(0)
  conditions      Json      @default("{}") // Targeting rules
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
}

model Webhook {
  id              String    @id @default(uuid())
  name            String
  url             String
  events          String[]
  secret          String
  isActive        Boolean   @default(true)
  retryPolicy     Json      @default("{\"maxRetries\": 3, \"backoffMs\": 1000}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  deliveries      WebhookDelivery[]

  @@index([organizationId])
  @@index([isActive])
}

model WebhookDelivery {
  id              String    @id @default(uuid())
  webhookId       String
  event           String
  payload         Json
  responseStatus  Int?
  responseBody    String?
  error           String?
  attempt         Int       @default(1)
  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  webhook         Webhook   @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
}

model AuditLog {
  id              String    @id @default(uuid())
  action          String
  resource        String
  resourceId      String?
  oldValues       Json?
  newValues       Json?
  metadata        Json      @default("{}")
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())

  organizationId  String
  userId          String?

  user            User?     @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
}

model UsageMetric {
  id              String    @id @default(uuid())
  period          DateTime  // Start of billing period
  tokensIn        Int       @default(0)
  tokensOut       Int       @default(0)
  totalCostUsd    Float     @default(0)
  requestCount    Int       @default(0)
  errorCount      Int       @default(0)
  avgLatencyMs    Float?

  organizationId  String
  projectId       String?

  @@unique([organizationId, projectId, period])
  @@index([organizationId])
  @@index([period])
}

model InviteToken {
  id              String    @id @default(uuid())
  email           String
  role            UserRole
  token           String    @unique
  expiresAt       DateTime
  usedAt          DateTime?
  createdAt       DateTime  @default(now())

  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedById     String
  invitedBy       User      @relation("InvitedTokens", fields: [invitedById], references: [id])

  @@index([organizationId])
  @@index([token])
}

model UserPermission {
  id              String    @id @default(uuid())
  permission      Permission
  scope           String?   // Optional scope (e.g., project ID)
  grantedAt       DateTime  @default(now())
  grantedBy       String?   // User ID who granted this permission

  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission, scope])
  @@index([userId])
  @@index([permission])
}