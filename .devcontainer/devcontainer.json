{
  "name": "Lawful Nova Agentic Shell",
  "build": { "dockerfile": "Dockerfile", "context": ".." },
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/node:1": { "version": "20" },
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" },
    "ghcr.io/devcontainers/features/nvidia-cuda:1": { "cudaVersion": "12" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "eamodio.gitlens",
        "ms-python.python",
        "timonwong.shellcheck",
        "foxundermoon.shell-format",
        "GitHub.copilot",
        "GitHub.vscode-pull-request-github",
        "usernamehw.errorlens",
        "PKief.material-icon-theme",
        "ms-vscode-remote.remote-containers"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "postCreateCommand": "bash setup/bootstrap.sh",
  "remoteUser": "vscode",
  "containerEnv": {
    "NOVA_PORT": "${localEnv:NOVA_PORT}",
    "NOVA_API_URL": "${localEnv:NOVA_API_URL}",
    "NOVA_CLI": "${localEnv:NOVA_CLI}",
    "NOVA_VOSS_RUNTIME_PATH": "${localEnv:NOVA_VOSS_RUNTIME_PATH}",
    "NOVA_CORTEX_PATH": "${localEnv:NOVA_CORTEX_PATH}",
    "NOVA_GOW_CONFIG": "${localEnv:NOVA_GOW_CONFIG}",
    "NOVA_RSL_PATH": "${localEnv:NOVA_RSL_PATH}",
    "NOVA_GPU_DEVICE": "${localEnv:NOVA_GPU_DEVICE}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "CUDA_VISIBLE_DEVICES": "${localEnv:NOVA_GPU_DEVICE}"
  },
  "runArgs": ["--gpus", "all"],
  "forwardPorts": [8080, 5000, 3000]
}
