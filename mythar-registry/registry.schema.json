{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mythar.dev/schemas/constitutional-registry-0.1.json",
  "title": "Mythar Constitutional Registry",
  "type": "object",
  "required": ["registry", "roots", "roles", "operators", "particles", "grammar", "semantic_graph", "compilation", "validation"],
  "properties": {
    "registry": {"type":"object","required":["id","version","status","source"]},
    "roots": {"type":"array","minItems":13,"items":{"type":"object","required":["id","form","domain","meanings","default_polarity","phonology"],"properties":{"id":{"type":"string"},"form":{"type":"string","pattern":"^[a-z]+$"},"domain":{"type":"string"},"meanings":{"type":"array","minItems":1,"items":{"type":"string"}},"default_polarity":{"enum":["positive","neutral","negative","contextual"]},"phonology":{"type":"string"}}}},
    "roles": {"type":"object"},
    "operators": {"type":"object","required":["prefixes","suffixes"]},
    "particles": {"type":"array","minItems":4},
    "grammar": {"type":"object","required":["sentence","phonology","word_formation"]},
    "semantic_graph": {"type":"object","required":["kind","node_types","edge_types","constraints"]},
    "compilation": {"type":"object","required":["stages","required_output","reduction"]},
    "validation": {"type":"object","required":["invariants","diagnostics"]}
  }
}
