{
  "compilerOptions": {
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "typeRoots": ["./node_modules/@types", "./src/types"]
  },
  "include": ["src/**/*", "config/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "cockpit",
    "ulx",
    "agent",
    "agent/**/*",
    "src/agent",
    "src/cli",
    "src/code",
    "src/core",
    "src/governance",
    "src/model",
    "src/runtime",
    "src/tools",
    "src/prompts",
    "agent/**/node_modules"
  ]
}