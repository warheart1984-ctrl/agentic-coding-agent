{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "moduleResolution": "node"
  },
  "include": [
    "agent/**/*",
    "src/**/*",
    "bin/**/*",
    "tests/**/*",
    "config/nova.config.ts",
    "crk2/**/*",
    "control-tower/**/*",
    "backend/**/*",
    "tools/**/*"
  ],
  "exclude": ["node_modules", "dist", "examples", "cockpit"]
}
