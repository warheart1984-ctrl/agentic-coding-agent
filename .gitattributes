# Auto-detect and normalize to LF for code files
* text=auto

# TypeScript/JavaScript — LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf

# Markdown/Text — LF
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.html text eol=lf

# Shell scripts — LF
*.sh text eol=lf
*.bash text eol=lf

# PowerShell — CRLF (PowerShell 5.1 requires CRLF)
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.psd1 text eol=crlf

# Windows batch — CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no diff
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.tar binary
*.blob binary
*.exe binary
*.dmg binary
*.AppImage binary
*.deb binary
*.rpm binary

# Lock files — linguist-generated
package-lock.json linguist-generated
